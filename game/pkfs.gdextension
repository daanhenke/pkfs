[configuration]
entry_symbol = "gdext_rust_init"
compatibility_minimum = 4.2
reloadable = true

[libraries]
windows.debug.x86_64 = "res://bin/pkfs_gdext.dll"
windows.release.x86_64 = "res://bin/pkfs_gdext.dll"
linux.debug.x86_64 = "res://bin/libpkfs_gdext.so"
linux.release.x86_64 = "res://bin/libpkfs_gdext.so"
